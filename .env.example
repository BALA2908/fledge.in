# Supabase — copy this file to .env.local and fill in from
# Supabase Dashboard → Project Settings → API
# URL is the bare project URL — no /rest/v1/ suffix.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Never expose to the browser, never commit real values here.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# ── Code-execution engine (Phase 4 judge) ──────────────────────────────
# Pick ONE backend. Auto-selects judge0 when JUDGE0_KEY is set, else piston.
# Force it explicitly with JUDGE_BACKEND = piston | judge0.
JUDGE_BACKEND=

# Backend A — Judge0 via RapidAPI CE (zero infra; free tier ~50 runs/day).
# Get a key at rapidapi.com/judge0-official/api/judge0-ce (free plan).
JUDGE0_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com
JUDGE0_URL=https://judge0-ce.p.rapidapi.com

# Backend B — self-hosted Piston. Base URL, no trailing slash, no /execute.
# e.g. https://<vm-ip>.nip.io/api/v2  (see piston/gcp-setup.sh)
PISTON_URL=
# Optional: cap run_timeout to your instance's limit (ms).
PISTON_MAX_RUN_MS=3000
# Optional shared secret — sent as Authorization: Bearer <secret> so only
# this backend can reach your Piston (the gcp-setup Caddy proxy checks it).
PISTON_SECRET=
