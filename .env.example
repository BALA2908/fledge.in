# Supabase — copy this file to .env.local and fill in from
# Supabase Dashboard → Project Settings → API
# URL is the bare project URL — no /rest/v1/ suffix.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Never expose to the browser, never commit real values here.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Code-execution engine (Phase 4 judge). The public emkc.org Piston API is
# whitelist-only since 2026-02-15, so point this at your own Piston instance.
# Base URL WITHOUT a trailing slash and WITHOUT /execute.
# e.g. https://your-piston-host.fly.dev/api/v2/piston
PISTON_URL=
