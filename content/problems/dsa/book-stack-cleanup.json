  "reference_solution": {
    "python": "import sys\n\ndef solve(s):\n    row = []\n    for c in s:\n        if row and row[-1] == c:\n            row.pop()\n        else:\n            row.append(c)\n    return \"\".join(row) if row else \"EMPTY\"\n\ndef main():\n    data = sys.stdin.read().split()\n    t = int(data[0])\n    out = []\n    for i in range(1, t + 1):\n        out.append(solve(data[i]))\n    sys.stdout.write(\"\\n\".join(out) + \"\\n\")\n\nmain()\n"
  },
