  "reference_solution": {
    "python": "import sys\n\ndef edit_distance(a, b):\n    # rolling-row DP, O(len(a) * len(b)) time, O(min) memory\n    if len(a) < len(b):\n        a, b = b, a\n    prev = list(range(len(b) + 1))\n    for i, ca in enumerate(a, 1):\n        cur = [i]\n        append = cur.append\n        diag = i - 1\n        left = i\n        j = 0\n        for cb in b:\n            j += 1\n            up = prev[j]\n            if ca == cb:\n                v = diag\n            else:\n                v = diag\n                if up < v:\n                    v = up\n                if left < v:\n                    v = left\n                v += 1\n            append(v)\n            diag = up\n            left = v\n        prev = cur\n    return prev[-1]\n\ndef main():\n    data = sys.stdin.read().split()\n    t = int(data[0])\n    pos = 1\n    out = []\n    for _ in range(t):\n        p, c = data[pos], data[pos + 1]; pos += 2\n        out.append(str(edit_distance(p, c)))\n    sys.stdout.write(\"\\n\".join(out) + \"\\n\")\n\nmain()\n"
  },
