  "reference_solution": {
    "python": "import sys\nfrom math import gcd\n\ndef main():\n    data = sys.stdin.read().split()\n    pos = 0\n    t = int(data[pos]); pos += 1\n    out = []\n    for _ in range(t):\n        a, b = int(data[pos]), int(data[pos + 1]); pos += 2\n        out.append(str(gcd(a, b)))\n    sys.stdout.write(\"\\n\".join(out) + \"\\n\")\n\nmain()\n"
  },
