  "starter_code": {
    "python": "import sys\n\ndef solve_case(a, b):\n    # your code here — return the largest tile side for an a x b courtyard\n    return 1\n\ndef main():\n    data = sys.stdin.read().split()\n    pos = 0\n    t = int(data[pos]); pos += 1\n    for _ in range(t):\n        a, b = int(data[pos]), int(data[pos + 1]); pos += 2\n        print(solve_case(a, b))\n\nmain()\n",
    "java": "import java.io.*;\nimport java.util.*;\n\npublic class Main {\n    static long solveCase(long a, long b) {\n        // your code here — return the largest tile side for an a x b courtyard\n        return 1;\n    }\n\n    public static void main(String[] args) throws IOException {\n        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));\n        StringBuilder sb = new StringBuilder();\n        for (String line = br.readLine(); line != null; line = br.readLine()) sb.append(line).append(' ');\n        StringTokenizer st = new StringTokenizer(sb.toString());\n        int t = Integer.parseInt(st.nextToken());\n        StringBuilder out = new StringBuilder();\n        while (t-- > 0) {\n            long a = Long.parseLong(st.nextToken());\n            long b = Long.parseLong(st.nextToken());\n            out.append(solveCase(a, b)).append('\\n');\n        }\n        System.out.print(out);\n    }\n}\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\n\nlong long solve_case(long long a, long long b) {\n    // your code here — return the largest tile side for an a x b courtyard\n    return 1;\n}\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int t;\n    cin >> t;\n    while (t--) {\n        long long a, b;\n        cin >> a >> b;\n        cout << solve_case(a, b) << '\\n';\n    }\n    return 0;\n}\n",
    "javascript": "const toks = require(\"fs\").readFileSync(0, \"utf8\").split(/\\s+/).filter(Boolean);\nlet pos = 0;\nconst t = Number(toks[pos++]);\nconst out = [];\nfor (let i = 0; i < t; i++) {\n  const a = BigInt(toks[pos++]);\n  const b = BigInt(toks[pos++]);\n  out.push(solveCase(a, b).toString());\n}\nconsole.log(out.join(\"\\n\"));\n\nfunction solveCase(a, b) {\n  // your code here — a and b are BigInt; return the largest tile side as a BigInt\n  return 1n;\n}\n"
